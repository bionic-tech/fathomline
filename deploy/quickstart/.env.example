# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.
#   cp .env.example .env && $EDITOR .env

# Catalogue DB password (used by postgres, migrate, and api). Generate a strong one:
#   openssl rand -base64 32
FATHOM_DB_PASSWORD=change-me

# Shared secret the mTLS proxy stamps on forwarded ingest requests so the API can prove a
# request transited the proxy (a direct call bypassing it is rejected). REQUIRED.
#   openssl rand -base64 48 | tr -d '/+=' | head -c 48
FATHOM_INGEST_PROXY_SECRET=change-me-too

# Encryption key for in-app secrets (the runtime settings store: API keys, named secrets, encrypted
# settings). STRONGLY RECOMMENDED — without it the app mints an ephemeral per-process key and every
# in-app secret is LOST on each restart. Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The *_REF names the env var that holds the key; keep them paired.
FATHOM_SETTINGS_STORE_KEY_REF=FATHOM_SETTINGS_STORE_KEY
FATHOM_SETTINGS_STORE_KEY=change-me-fernet-key

# Where the API listens. Keep localhost until HTTPS/SSO fronts it.
#FATHOM_API_BIND=127.0.0.1
#FATHOM_API_PORT=8088

# Postgres memory ceiling (tune to your host).
#FATHOM_DB_MEM_LIMIT=2g
