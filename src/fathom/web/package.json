{
  "name": "fathom-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Fathom UI viewer — Vite + React + TypeScript SPA (ECharts). Built to dist/ and served same-origin by the FastAPI api container (ADR-007/ADR-012, frontend ADD §15).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "gen:api": "openapi-typescript http://localhost:8088/openapi.json -o src/api/generated/openapi.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "echarts": "^5.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.8.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^24.1.1",
    "openapi-typescript": "^7.3.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.3.5",
    "vitest": "^2.0.5"
  }
}
